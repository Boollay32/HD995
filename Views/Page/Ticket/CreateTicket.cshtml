@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section AddCSSToHead {
    <link rel="stylesheet" type="text/css" href="/css/Pages/CreateForm.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Addons/Snow.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Addons/PopupWindows.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Addons/NotesTable.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Addons/FormLayout.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Addons/Attachment.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Pages/DetailForm.css" asp-append-version="true">
}

@section AddJSToHead {
    <script src="~/js/Components/CustomFields/CustomFieldBuilder.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Pages/CreateTicket.js" asp-append-version="true"></script>
}

<div id="Main-Div" class="main-section dform dform-ticket">
    <div id="Detail-Container">
        <div id="Detail-Header">
            @* Fix: empty <a> removed *@
            <div id="header-buttons">
                @* Fix: onclick removed — handled in CreateTicket.js *@
                <button type="button" id="SubmitCreatedTicket" class="accept">Submit</button>
            </div>
        </div>

        <div id="Detail-Body">
            <form id="create-ticket">
                <div id="Detail-Inner">
                    <div id="Details">

                        <div class="ct-col ct-col--general">

                        <div id="Group-Header">
                            <div class="left">
                                @* Fix: missing space before class *@
                                <label id="GTI" class="Name">General Ticket Information</label>
                            </div>
                        </div>

                        @* Request Type *@
                        @* Fix: id="Detail-Div", id="left", id="right" → classes — were duplicated *@
                        <div class="Detail-Div full">
                            <div class="left">
                                <label class="Name">Request Type</label>
                            </div>
                            <div class="right">
                                @* Fix: onchange removed — handled in CreateTicket.js *@
                                <select required id="requestType" class="Value"></select>
                            </div>
                        </div>

                        @* Subject *@
                        <div class="Detail-Div full">
                            <div class="left">
                                <label class="Name" for="subject">Subject</label>
                            </div>
                            <div class="right">
                                <input required id="subject" class="Value" type="text">
                            </div>
                        </div>

                        @* Description *@
                        <div class="Detail-Div full">
                            <div class="left">
                                <label class="Name" for="requestDetail">Description</label>
                            </div>
                            <div class="right">
                                @* Fix: inline style + onkeydown removed — moved to CSS/JS *@
                                <textarea required id="requestDetail" class="Value"></textarea>
                            </div>
                        </div>

                        @* Attachments *@
                        @* Fix: inline style height:80px — moved to CSS *@
                        <div class="Detail-Div full attachment-row">
                            <div class="left">
                                <label class="Name">Attachments</label>
                                @* Fix: ondrop removed — handled in Attachments.js *@
                                <div id="AttachBin">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66L9.41 17.41a2 2 0 01-2.83-2.83l8.49-8.48" />
                                    </svg>
                                    <span>Drag &amp; drop files</span>
                                </div>
                            </div>
                            <div id="CreateNoteAttachmentList" name="MainNoteAttachHolder">
                                <div class="Attachment-Icon" id="Attachment-Icon1" draggable="true">
                                    <div value="" class="File-ImageUnset" id="File-Image1">
                                        <img src="images/PlusIcon.png">
                                    </div>
                                    @* Fix: inline style opacity:0 — moved to CSS *@
                                    @* Fix: onchange removed — handled in Attachments.js *@
                                    <input type="file" title=" " class="FileUP"
                                           name="Value" value="1" id="fileupload1">
                                    @* Fix: inline style padding — moved to CSS *@
                                    <label id="Attach-Label" class="attach-label"></label>
                                    <button type="button" class="attachment-remove" aria-label="Remove attachment" tabindex="-1"><svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                                </div>
                            </div>
                        </div>

                        </div>

                        <div class="ct-col ct-col--custom">
                            <div class="Group-Header">
                                <div class="left">
                                    <label class="Name">Request Details</label>
                                </div>
                            </div>

                            <div id="Custom-fields"></div>
                        </div>

                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="Display-Div"></div>
