@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "New ticket";
}

@section AddCSSToHead {
    <link rel="stylesheet" type="text/css" href="/css/Addons/Snow.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Addons/PopupWindows.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Pages/CreateTicket.css" asp-append-version="true">
}

@section AddJSToHead {
    <script src="~/js/Components/CustomFields/CustomFieldBuilder.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Pages/CreateTicket.js" asp-append-version="true"></script>
}

<div id="Main-Div" class="create-app">

    <header class="ca-head">
        <h1>New ticket</h1>
        <button type="button" id="SubmitCreatedTicket" class="ca-btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            <span>Create ticket</span>
        </button>
    </header>

    <form id="create-ticket" class="ca-body">

        @* ---- General information ---- *@
        <section class="ca-panel">
            <header class="ca-panel-head"><h2>General information</h2></header>
            <div class="ca-panel-body">

                <div class="Detail-Div full">
                    <div class="left"><label class="Name" for="requestType">Request type</label></div>
                    <div class="right">
                        <select required id="requestType" class="Value"></select>
                    </div>
                </div>

                <div class="Detail-Div full">
                    <div class="left"><label class="Name" for="subject">Subject</label></div>
                    <div class="right">
                        <input required id="subject" class="Value" type="text">
                    </div>
                </div>

                <div class="Detail-Div full">
                    <div class="left"><label class="Name" for="requestDetail">Description</label></div>
                    <div class="right">
                        <textarea required id="requestDetail" class="Value"></textarea>
                    </div>
                </div>

                <div class="Detail-Div full ca-attach-row">
                    <div class="left"><label class="Name">Attachments</label></div>
                    <div class="right">
                        <div id="AttachBin">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66L9.41 17.41a2 2 0 01-2.83-2.83l8.49-8.48" />
                            </svg>
                            <span>Drag &amp; drop files or click to browse</span>
                        </div>
                        <input type="file" id="ct-file-input" multiple hidden aria-label="Attach files" />
                        <div id="ct-attachment-list" aria-live="polite"></div>
                    </div>
                </div>

            </div>
        </section>

        @* ---- Request details (custom fields) ---- *@
        <section class="ca-panel ca-panel--custom">
            <header class="ca-panel-head"><h2>Request details</h2></header>
            <div id="Custom-fields" class="ca-panel-body"></div>
        </section>

    </form>

</div>

<div id="Display-Div"></div>
