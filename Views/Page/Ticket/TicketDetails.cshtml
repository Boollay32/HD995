@using HelpDeskNet8.Models.ViewModels
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Ticket details";
}

@section AddJSToHead {
    <script src="~/js/Components/CustomFields/CustomFieldBuilder.js" asp-append-version="true"></script>
    <script src="~/js/Components/Notes/NotesPanel.js" asp-append-version="true"></script>
    <script src="~/js/Components/Notes/Notes.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/Features/TaskPopulation.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/Features/Tasks.js" asp-append-version="true"></script>
    <script src="~/js/Components/Activity/Activity.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Features/TicketFields.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Features/TicketLoader.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Features/TicketSave.js" asp-append-version="true"></script>
    <script src="~/js/Components/Shell/PaneShell.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Features/TicketShell.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Pages/TicketDetails.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Features/PillEdit.js" asp-append-version="true"></script>
    <script src="~/js/Components/Overview/OverviewCollapse.js" asp-append-version="true"></script>
    <script src="~/js/Ticket/Features/OverviewPanel.js" asp-append-version="true"></script>
}

@section AddCSSToHead {
    <link rel="stylesheet" type="text/css" href="/css/Components/NoteThread.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Components/PaneShell.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Pages/DetailShared.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Pages/TicketDetails.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Components/Tasks.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Pages/TicketOverlay.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Pages/TicketActivity.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Pages/TicketComposer.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="/css/Pages/TicketOverview.css" asp-append-version="true" />
}

<a href="#pane-left" class="skip-link">Skip to ticket content</a>

<div class="td-app" id="TicketDetails-App">

    <!-- ═══════════════════  TOPBAR  ═══════════════════ -->
    <div class="td-header-panel">
    <header class="td-topbar" role="banner" id="Detail-Header">

        <button class="td-back" id="Back-Button" aria-label="Back to ticket list" type="button">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 18l-6-6 6-6" />
            </svg>
        </button>

        <div class="td-id-block">
            <span class="td-tid mono" id="TicketID"></span>
        </div>

        <div class="td-topbar-meta" id="Topbar-Meta">
            <!-- pills populated by JS; captions are static -->
            <div class="td-meta-group">
                <span class="td-meta-cap">Status</span>
                <div class="td-meta-pill" id="meta-status"></div>
            </div>
            <div class="td-meta-group">
                <span class="td-meta-cap">Priority</span>
                <div class="td-meta-pill" id="meta-priority"></div>
            </div>
            <div class="td-meta-group">
                <span class="td-meta-cap">Category</span>
                <div class="td-meta-pill" id="meta-category"></div>
            </div>
            <div class="td-meta-group" id="meta-sla-group">
                <span class="td-meta-cap">Due</span>
                <div class="td-meta-pill" id="meta-sla"></div>
            </div>
            <div class="td-meta-group" id="meta-project-group" hidden>
                <span class="td-meta-cap">Project</span>
                <button type="button" class="td-meta-pill td-meta-project" id="meta-project"
                        aria-label="Open this ticket's project"></button>
            </div>
        </div>

        <div class="td-spacer"></div>

        <div class="td-topbar-actions" id="header-buttons">
            <button type="button" class="td-btn-ghost hidden" id="FalseReply">
                Hide Notification
            </button>
            <button type="button" class="td-btn-primary" id="Save-Button" disabled>Save Changes</button>
        </div>

    </header>

    </div>


    <!-- ═══════════════════  SHELL  ═══════════════════ -->
    <div class="td-shell" id="TD-Shell" role="main" data-layout="@ViewBag.BootLayout">

        <!-- ── LEFT PANE (Messages) ── -->
        <div class="td-pane td-pane--left" id="pane-left" aria-label="Messages">
            <div class="td-rail" id="rail-left" aria-hidden="true" tabindex="-1">
                <span class="td-rail-label">Messages</span>
                <span class="td-rail-pip mono hidden" id="rail-left-pip"></span>
            </div>
            <div class="td-pane-inner" id="pane-left-inner">
                <!-- ── Pane Header ── -->
                <div class="td-pane-head">
                    <h2 class="td-pane-title">Messages</h2>
                    <span class="td-unread-badge hidden mono" id="msg-unread-badge"></span>
                    <button class="td-collapse-btn" id="collapse-left"
                            aria-label="Collapse messages pane"
                            aria-expanded="true"
                            aria-controls="pane-left"
                            type="button">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M15 18l-6-6 6-6" />
                        </svg>
                    </button>
                </div>

                <!-- ── Thread ── -->
                <!-- scope reminder (Govtech only; shown/dismissed by NotesPanel in messages mode) -->
                <div class="td-scope-note td-scope-note--msg" id="msg-scope-banner" hidden>
                    <button type="button" class="td-scope-dismiss"
                            id="msg-scope-dismiss" aria-label="Dismiss reminder">&times;</button>
                    <span class="td-scope-text">Visible to the client — messages here are sent to the requester.</span>
                </div>

                <div class="td-thread" id="Messages-Thread" role="log" aria-live="polite" aria-label="Message thread">
                    <!-- items injected by NotesPanel in messages mode -->
                </div>

                <!-- ── Composer ── -->
                <div class="td-composer-dock" id="Messages-Compose">

                    <div class="td-composer" id="msg-composer-box">
                        <textarea id="msg-textarea"
                                  class="td-composer-input"
                                  placeholder="Write a message…"
                                  maxlength="2000"
                                  rows="1"
                                  aria-label="Message text"
                                  aria-describedby="msg-charcount"></textarea>

                        <button type="button" class="td-send-btn" id="msg-send-btn"
                                aria-label="Send message" disabled>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="22" y1="2" x2="11" y2="13" />
                                <polygon points="22 2 15 22 11 13 2 9 22 2" />
                            </svg>
                        </button>
                    </div>

                    <div class="td-composer-footer">
                        <span class="td-charcount mono" id="msg-charcount" aria-live="polite">0 / 2000</span>

                        <div class="td-composer-attachments" id="msg-attachment-list">
                            <!-- attachment slots injected by JS -->
                        </div>

                        <label class="td-attach-btn" aria-label="Add attachment">
                            <input type="file" id="msg-file-input" class="sr-only"
                                   multiple accept="*/*"
                                   aria-label="Attach file to message" />
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66L9.41 17.41a2 2 0 01-2.83-2.83l8.49-8.48" />
                            </svg>
                        </label>
                    </div>

                </div>

            </div>
        </div>

        <!-- ── DRAG DIVIDER ── -->
        <div class="td-divider" id="pane-divider" role="separator"
             aria-orientation="vertical" aria-label="Resize panes"
             tabindex="0"><span class="td-divider-grip" aria-hidden="true"></span></div>

        <!-- ── RIGHT PANE (Workspace) ── -->
        <div class="td-pane td-pane--right" id="pane-right" aria-label="Workspace">
            <div class="td-rail" id="rail-right" aria-hidden="true" tabindex="-1">
                <span class="td-rail-label">Workspace</span>
            </div>
            <div class="td-pane-inner" id="pane-right-inner">
                <!-- OVERVIEW (moved into workspace column - HD38 #5) -->
    <section class="td-overview" id="Ticket-Overview" aria-label="Ticket overview">
                <button type="button" class="td-ov-collapse" id="ov-collapse"
                    aria-label="Collapse overview" aria-expanded="true"
                    aria-controls="Ticket-Overview">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 15l-6-6-6 6" />
                </svg>
            </button>

        <span class="td-ov-lbl td-subject-lbl">Title</span>
        <h2 class="td-details-subject" id="subject"></h2>

        <div class="td-ov-body">

            <div class="td-ov-group">
                <h3 class="td-ov-grp-head">Origin</h3>
                <div class="td-ov-grid">
                    <div class="td-ov-cell">
                        <div class="td-ov-lbl">Request type</div>
                        <label class="Field-Value" id="requesttype"></label>
                    </div>
                    <div class="td-ov-cell">
                        <div class="td-ov-lbl">From</div>
                        <label class="Field-Value" id="raisedby"></label>
                    </div>
                    <div class="td-ov-cell">
                        <div class="td-ov-lbl">Authority</div>
                        <label class="Field-Value" id="authority"></label>
                    </div>
                    <div class="td-ov-cell">
                        <div class="td-ov-lbl">Assigned to</div>
                        <select id="assignedtech" class="td-select" aria-label="Assigned technician"></select>
                    </div>
                </div>
            </div>

            <div class="td-ov-group">
                <h3 class="td-ov-grp-head">Timeline</h3>
                <div class="td-ov-timeline">
                    <div class="td-ov-node">
                        <div class="td-ov-lbl"><span class="td-ov-dot"></span>Created</div>
                        <label class="Field-Value mono" id="created"></label>
                    </div>
                    <div class="td-ov-arrow">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                    </div>
                    <div class="td-ov-node">
                        <div class="td-ov-lbl"><span class="td-ov-dot"></span>First response</div>
                        <label class="Field-Value" id="ov-first-response">&mdash;</label>
                    </div>
                    <div class="td-ov-arrow">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                    </div>
                    <div class="td-ov-node">
                        <div class="td-ov-lbl"><span class="td-ov-dot"></span><span id="ov-needed-lbl-text">Needed by</span></div>
                        <input type="date" id="targetdate" class="td-input" aria-label="Target date" />
                        <label class="Field-Value mono" id="ov-last-updated" hidden>&mdash;</label>
                    </div>
                    <div class="td-ov-arrow">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                    </div>
                    <div class="td-ov-node">
                        <div class="td-ov-lbl"><span class="td-ov-dot"></span>Closed</div>
                        <label class="Field-Value mono" id="closed"></label>
                    </div>
                </div>
            </div>

            <div class="td-ov-group" id="ov-desc-group" hidden>
                <div class="td-ov-desc-head">
                    <h3 class="td-ov-grp-head">Description</h3>
                    <button type="button" class="td-ov-desc-edit" id="ov-desc-edit" hidden>Edit</button>
                </div>
                <div class="td-ov-desc-body" id="ov-desc-body"></div>
                <div class="td-ov-desc-atts" id="ov-desc-atts"></div>
            </div>

        </div>

        <div class="td-ov-slim" id="ov-slim" aria-hidden="true">
            <span><span class="td-ov-slim-lbl">Type</span> <span class="Field-Value" id="ov-slim-type"></span></span>
            <span class="td-ov-sep">&middot;</span>
            <span><span class="td-ov-slim-lbl">From</span> <span class="Field-Value" id="ov-slim-from"></span></span>
            <span class="td-ov-sep">&rarr;</span>
            <span><span class="td-ov-slim-lbl">Assigned</span> <span class="Field-Value" id="ov-slim-assigned"></span></span>
            <span class="td-ov-sep">&middot;</span>
            <span><span class="td-ov-slim-lbl" id="ov-slim-needed-lbl">Needed by</span> <span class="Field-Value mono" id="ov-slim-needed"></span></span>
        </div>

    </section>

                <!-- ── Pane Header ── -->
                <div class="td-pane-head td-pane-head--ws">
                    <h2 class="td-pane-title">Workspace</h2>
                    <!-- tabs on the header row -->
                    <div class="td-ws-tabs" role="tablist" aria-label="Workspace sections">

                    <button role="tab" id="tab-details" aria-selected="true"
                            aria-controls="tabpanel-details" type="button">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        Details
                    </button>

                    <button role="tab" id="tab-tasks" aria-selected="false"
                            aria-controls="tabpanel-tasks" type="button">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="9 11 12 14 22 4" />
                            <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
                        </svg>
                        Tasks
                        <span class="td-tab-pip mono hidden" id="tasks-pip"></span>
                    </button>

                    <button role="tab" id="tab-notes" aria-selected="false"
                            aria-controls="tabpanel-notes" type="button">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                        </svg>
                        Notes
                        <span class="td-tab-pip mono hidden" id="notes-pip"></span>
                    </button>

                    <button role="tab" id="tab-activity" aria-selected="false"
                            aria-controls="tabpanel-activity" type="button">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                        </svg>
                        Activity
                    </button>

                    </div>

                    <button class="td-collapse-btn" id="collapse-right"
                            aria-label="Collapse workspace pane"
                            aria-expanded="true"
                            aria-controls="pane-right"
                            type="button">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M9 18l6-6-6-6" />
                        </svg>
                    </button>
                </div>

                <!-- ── Tab Panels ── -->
                <div class="td-ws-body">

                    <!-- NOTES -->
                    <div role="tabpanel" id="tabpanel-notes"
                         aria-labelledby="tab-notes"
                         class="td-ws-inner" hidden>

                        <!-- scope banner — id required by Notes.js Dom.scopeNote() -->
                        <div class="td-scope-note" id="note-scope-banner" hidden>
                            <button type="button" class="td-scope-dismiss"
                                    id="note-scope-dismiss" aria-label="Dismiss reminder">&times;</button>
                            <span class="td-scope-text" id="note-scope-text">
                                <span class="td-lock-icon" aria-hidden="true">🔒</span>
                                Internal only — not visible to client
                            </span>
                        </div>

                        <div class="td-note-thread" id="Notes-Thread" role="log"
                             aria-live="polite" aria-label="Internal notes">
                        </div>

                        <!-- compose dock — id required by Notes.js Dom.composeDock() -->
                        <div class="td-note-compose" id="Notes-Compose">
                            <div class="td-note-compose-row">
                            <textarea id="note-textarea"
                                      class="td-note-input"
                                      placeholder="Add an internal note…"
                                      maxlength="2000"
                                      rows="1"
                                      aria-label="Note text"
                                      aria-describedby="note-charcount"></textarea>

                            <button type="button" class="td-note-add-btn" id="note-send-btn"
                                    aria-label="Save note" disabled>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.2"
                                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <line x1="12" y1="5" x2="12" y2="19" />
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                </svg>
                            </button>
                        </div>

                        <div class="td-composer-footer">
                            <span class="td-charcount mono" id="note-charcount" aria-live="polite">0 / 2000</span>
                            <div class="td-composer-attachments" id="note-attachment-list"></div>
                            <label class="td-attach-btn" aria-label="Add attachment to note">
                                <input type="file" id="note-file-input" class="sr-only"
                                       multiple accept="*/*"
                                       aria-label="Attach file to note" />
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.2"
                                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66L9.41 17.41a2 2 0 01-2.83-2.83l8.49-8.48" />
                                </svg>
                            </label>
                            <button type="button" class="td-visibility-btn hidden"
                                    id="note-visibility-btn"
                                    aria-label="Toggle client visibility"
                                    aria-pressed="false">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.2"
                                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            </button>
                        </div>
                        </div>

                    </div>

                    <!-- TASKS -->
                    <div role="tabpanel" id="tabpanel-tasks"
                         aria-labelledby="tab-tasks"
                         class="td-ws-inner" hidden>

                        <div class="td-progress-track" id="task-progress-track" aria-hidden="true">
                            <div class="td-progress-fill" id="task-progress-fill"
                                 role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"
                                 style="width:0%"></div>
                        </div>
                        <div class="td-tasks-bar">
                            <p class="td-progress-label" id="task-progress-label"></p>
                        </div>

                        <div class="td-task-list" id="Task-List" aria-label="Task list">
                            <!-- tasks injected by Tasks.js -->
                        </div>

                        <div class="td-tasks-foot">
                            <button type="button" class="td-btn-ghost td-add-task-btn" id="add-task-btn">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.2"
                                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <line x1="12" y1="5" x2="12" y2="19" />
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                </svg>
                                Add Task
                            </button>
                        </div>

                        <!-- Full-panel host for the NEW-task editor (compose mode) -->
                        <div class="td-task-compose" id="Task-Compose" hidden></div>

                        <!-- Task overlay -->
                        <div class="td-overlay" id="task-overlay" hidden>
                            <div class="td-overlay-panel" role="dialog"
                                 aria-modal="true" aria-labelledby="task-overlay-title">
                                <div class="td-overlay-head">
                                    <h3 id="task-overlay-title">Add Task</h3>
                                    <button type="button" class="td-overlay-close"
                                            id="task-overlay-close" aria-label="Close">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2.5"
                                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <line x1="18" y1="6" x2="6" y2="18" />
                                            <line x1="6" y1="6" x2="18" y2="18" />
                                        </svg>
                                    </button>
                                </div>
                                <form id="task-overlay-form" novalidate>
                                    <div class="td-form-field">
                                        <label for="task-title-input">Title <span aria-hidden="true">*</span></label>
                                        <input type="text" id="task-title-input"
                                               class="td-input" required
                                               placeholder="Task title…"
                                               autocomplete="off" />
                                    </div>
                                    <div class="td-form-field">
                                        <label for="task-assignee">Assignee</label>
                                        <select id="task-assignee" class="td-select">
                                            <option value="">Unassigned</option>
                                        </select>
                                    </div>
                                    <div class="td-form-field">
                                        <label for="task-due-date">Due Date</label>
                                        <input type="date" id="task-due-date" class="td-input" />
                                    </div>
                                    <div class="td-form-field">
                                        <label for="task-priority">Priority</label>
                                        <select id="task-priority" class="td-select">
                                            <option value="1">Low</option>
                                            <option value="2" selected>Medium</option>
                                            <option value="3">High</option>
                                        </select>
                                    </div>
                                    <div class="td-overlay-actions">
                                        <button type="button" class="td-btn-ghost"
                                                id="task-cancel-btn">
                                            Cancel
                                        </button>
                                        <button type="submit" class="td-btn-primary"
                                                id="task-save-btn">
                                            Save Task
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                    </div>


                    <!-- DETAILS -->
                    <div role="tabpanel" id="tabpanel-details"
                         aria-labelledby="tab-details"
                         class="td-ws-inner" hidden>

                        <!-- Status / Priority / Category dropdown sources.
                             Hidden <select>s populated by Dropdowns.load; the save
                             source for these fields. PillEdit renders them as the
                             topbar meta dropdowns. -->
                        <div id="ticket-meta-selects" hidden>
                            <select id="status" class="td-select" aria-label="Status"></select>
                            <select id="priority" class="td-select" aria-label="Priority"></select>
                            <select id="category" class="td-select" aria-label="Category"></select>
                        </div>

                        <!-- Group: Custom Fields -->
                        <div class="td-field-group" id="CustomFields-Group">
                            <dl class="td-dl" id="CustomFields-Container">
                                <!-- injected by CustomFieldBuilder.js -->
                            </dl>
                        </div>

                        <!-- Empty state: shown when the ticket has no Extended Information. -->
                        <div class="td-thread-empty" id="Details-Empty" hidden>
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" y1="8" x2="12" y2="12" />
                                <line x1="12" y1="16" x2="12.01" y2="16" />
                            </svg>
                            <p>No extra details present on this ticket.</p>
                        </div>

                    </div>

                    <!-- ACTIVITY -->
                    <div role="tabpanel" id="tabpanel-activity"
                         aria-labelledby="tab-activity"
                         class="td-ws-inner" hidden>

                        <ul class="td-timeline" id="Activity-List" aria-label="Ticket activity">
                            <!-- injected by GetHistory -->
                        </ul>

                    </div>

                </div>

            </div>
        </div>


    </div>

</div>
