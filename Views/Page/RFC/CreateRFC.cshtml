@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "New RFC";
}

@section AddCSSToHead {
    <link rel="stylesheet" type="text/css" href="/css/Addons/Snow.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Addons/PopupWindows.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Pages/CreateRFC.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/css/Components/NoteThread.css" asp-append-version="true">
}

@section AddJSToHead {
    <script src="~/js/RFC/Pages/CreateRFC.js" asp-append-version="true"></script>
}

<div id="Main-Div" class="create-app">

    <header class="ca-head">
        <h1>New RFC</h1>
        <button type="button" id="SubmitCreatedRFC" class="ca-btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            <span>Submit RFC</span>
        </button>
    </header>

    <form id="create-rfc" class="ca-body">

        <section class="ca-panel">
            <header class="ca-panel-head"><h2>General information</h2></header>
            <div class="ca-panel-body">
                <div class="ca-grid">

                    <div class="Detail-Div full">
                        <div class="left"><label class="Name" for="Title">Title</label></div>
                        <div class="right"><input required maxlength="250" id="Title" class="Value" /></div>
                    </div>

                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="Priority">Priority</label></div>
                            <div class="right"><select required id="Priority" class="Value"><option value="1">Emergency</option><option value="2">High</option><option value="3">Medium</option><option value="4">Low</option></select></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="Status">Status</label></div>
                            <div class="right"><select required id="Status" class="Value"><option value="1">Draft</option><option value="2">New</option><option value="3">Approved</option><option value="4">Rejected</option><option value="5">Approved with condition</option><option value="6">Incomplete</option><option value="7">Complete</option><option value="8">In Progress</option></select></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="assignedTechName">Assigned To</label></div>
                            <div class="right"><select id="assignedTechName" class="Value"></select></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="TargetDate">Target Date</label></div>
                            <div class="right"><input required type="date" id="TargetDate" class="Value" /></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="Environment">Environment</label></div>
                            <div class="right"><select required id="Environment" class="Value"><option value="1">Live</option><option value="2">Test</option><option value="3">Live and Test</option></select></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="ApprovedBy">Approved By</label></div>
                            <div class="right"><input id="ApprovedBy" class="Value"></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="ApprovalDate">Approval Date</label></div>
                            <div class="right"><input type="date" id="ApprovalDate" class="Value"></div>
                        </div>

                </div>
            </div>
        </section>

        <section class="ca-panel ca-panel--custom">
            <header class="ca-panel-head"><h2>Assessment details</h2></header>
            <div class="ca-panel-body">

                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="Description">Description</label></div>
                            <div class="right"><textarea required maxlength="1000" id="Description" class="Value"></textarea></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="AffectedBusinessSystemsOrServices">Affected Business Systems or Services</label></div>
                            <div class="right"><textarea required maxlength="1000" id="AffectedBusinessSystemsOrServices" class="Value"></textarea></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="AffectedCustomers">Affected Customers</label></div>
                            <div class="right"><textarea required maxlength="250" id="AffectedCustomers" class="Value"></textarea></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="BusinessJustification">Business Justification</label></div>
                            <div class="right"><textarea required maxlength="1000" id="BusinessJustification" class="Value"></textarea></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="RiskAssessment">Risk Assessment</label></div>
                            <div class="right"><textarea required maxlength="1000" id="RiskAssessment" class="Value"></textarea></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="ImpactAnalysis">Impact Analysis</label></div>
                            <div class="right"><textarea required maxlength="1000" id="ImpactAnalysis" class="Value"></textarea></div>
                        </div>
                        <div class="Detail-Div">
                            <div class="left"><label class="Name" for="InformationSecurityConsiderations">Information Security Considerations</label></div>
                            <div class="right"><textarea required maxlength="1000" id="InformationSecurityConsiderations" class="Value"></textarea></div>
                        </div>

                <div class="Detail-Div full ca-attach-row">
                    <div class="left"><label class="Name">Attachments</label></div>
                    <div class="right">
                        <div class="td-composer-footer">
                            <label class="td-attach-btn" aria-label="Add attachment">
                                <input type="file" id="cr-file-input" class="sr-only" multiple accept="*/*" aria-label="Attach files" />
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66L9.41 17.41a2 2 0 01-2.83-2.83l8.49-8.48" />
                                </svg>
                            </label>
                            <div class="td-composer-attachments" id="cr-attachment-list" aria-live="polite"></div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

    </form>

</div>

<div id="Display-Div"></div>
