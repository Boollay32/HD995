@using HelpDeskNet8.Models.ViewModels
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section AddJSToHead {
    <script src="~/js/User/Features/UserFields.js" asp-append-version="true"></script>
    <script src="~/js/User/Features/UserSave.js" asp-append-version="true"></script>
    <script src="~/js/User/Features/UserLoader.js" asp-append-version="true"></script>
    <script src="~/js/User/Pages/UserDetails.js" asp-append-version="true"></script>
}

@section AddCSSToHead {
    <link rel="stylesheet" type="text/css" href="/css/Pages/UserDetails.css" asp-append-version="true" />
}

<div class="ud-app" id="UserDetails-App">
    <div class="ud-shell">

        <header class="ud-topbar">
            <div class="ud-topbar-id">
                <span class="ud-eyebrow">User</span>
                <a id="UserID" class="ud-id"></a>
            </div>
            <div class="ud-actions">
                <button type="button" id="ResetUser-Button" class="ud-btn ud-btn--ghost" style="display:none;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6" /><path d="M3 12a9 9 0 0 1 15-6.7L21 8" /><path d="M3 22v-6h6" /><path d="M21 12a9 9 0 0 1-15 6.7L3 16" /></svg>
                    <span>Reset password</span>
                </button>
                <button type="button" id="DeleteUser-Button" class="ud-btn ud-btn--danger" style="display:none;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /></svg>
                    <span>Delete user</span>
                </button>
                <button type="button" id="UpdateUser-Button" class="ud-btn ud-btn--primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><path d="M17 21v-8H7v8" /><path d="M7 3v5h8" /></svg>
                    <span>Update user</span>
                </button>
            </div>
        </header>

        <form id="User-Form" class="ud-content" onsubmit="return false">

            <section class="ud-hero">
                <div id="User-Avatar" class="ud-avatar" aria-hidden="true"></div>
                <div class="ud-hero-text">
                    <label id="UserName" class="ud-name"></label>
                    <div class="ud-role"><span id="User-Role"></span></div>
                </div>
                <span id="User-Status-Pill" class="ud-pill ud-pill--ok">
                    <span class="ud-dot" aria-hidden="true"></span>
                    <span id="User-Status-Text">Active</span>
                </span>
            </section>

            <div class="ud-grid">
                <section class="ud-card">
                    <h2 class="ud-card-title">Contact</h2>
                    <div class="ud-field">
                        <span class="ud-label">Email</span>
                        <label id="UserEmail" class="ud-value ud-value--link"></label>
                    </div>
                    <div class="ud-field">
                        <label class="ud-label" for="UserPhone">Phone</label>
                        <input type="text" id="UserPhone" class="ud-input" autocomplete="off" disabled />
                    </div>
                </section>

                <section class="ud-card">
                    <h2 class="ud-card-title">Access &amp; role</h2>
                    <div class="ud-field">
                        <label class="ud-label" for="AdminLevel">Admin level</label>
                        <select id="AdminLevel" class="ud-select" disabled>
                            <option value="0">Authority User</option>
                            <option value="3">TNS User</option>
                            <option value="4">Govtech RFC User</option>
                            <option value="1">Govtech User</option>
                            <option value="5">Govtech TNS User</option>
                            <option value="2">Govtech Admin User</option>
                        </select>
                    </div>
                    <div class="ud-field">
                        <span class="ud-label">Authority</span>
                        <label id="Authority" class="ud-value"></label>
                    </div>
                </section>
            </div>

            <section class="ud-card">
                <h2 class="ud-card-title">Account</h2>
                <div class="ud-field-row">
                    <div class="ud-field">
                        <label class="ud-label" for="Locked">Locked</label>
                        <select id="Locked" class="ud-select" disabled>
                            <option value="0">No</option>
                            <option value="1">Yes</option>
                        </select>
                    </div>
                    <div class="ud-field">
                        <span class="ud-label">Last logged on</span>
                        <label id="LastConnectionDate" class="ud-value"></label>
                    </div>
                    <div class="ud-field">
                        <span class="ud-label">Active account</span>
                        <label id="Active-Account" class="ud-value">Yes</label>
                    </div>
                </div>
            </section>

        </form>
    </div>
</div>
